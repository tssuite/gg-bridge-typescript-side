{
  "name": "@tssuite/gg-bridge-typescript-side",
  "version": "0.0.2",
  "description": "The typescript side of a dart - bridge - typescript project",
  "homepage": "https://github.com/tssuite/gg-bridge-typescript-side",
  "bugs": "https://github.com/tssuite/gg-bridge-typescript-side/issues",
  "private": true,
  "license": "tssuite",
  "engines": {
    "node": ">=22.16.0"
  },
  "repository": {
    "type": "git",
    "url": "git+git@github.com:tssuite/gg-bridge-typescript-side.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run test && vite build && tsc --noEmit",
    "preview": "vite preview",
    "test": "pnpm run test:vitest && pnpm run test:e2e && pnpm run lint",
    "test:vitest": "vitest --coverage --no-file-parallelism --run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint"
  },
  "dependencies": {
    "@tssuite/gg-bridge-dart-typescript": "1.0.1"
  },
  "devDependencies": {
    "@esbuild/linux-x64": "^0.28.0",
    "@playwright/test": "^1.60.0",
    "@rollup/rollup-linux-x64-gnu": "^4.61.1",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-node": "^6.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8",
    "vitest-dom": "^0.1.1"
  },
  "overrides": {
    "vite": {
      "rollup": "npm:@rollup/wasm-node"
    }
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
